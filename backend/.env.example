# DocuMind Backend — Environment Variables
# ==========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Groq API ─────────────────────────────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use. Options:
#   llama-3.1-70b-versatile   ← best quality (default)
#   llama-3.1-8b-instant      ← faster, slightly lower quality
#   mixtral-8x7b-32768        ← great for long documents
#   gemma2-9b-it              ← lightweight
GROQ_MODEL=llama-3.1-70b-versatile

# ── Embeddings ───────────────────────────────────────────────────────────
# HuggingFace model for local embeddings (downloads ~22 MB on first run)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── ChromaDB ─────────────────────────────────────────────────────────────
# Directory where ChromaDB persists vector data
CHROMA_PERSIST_DIR=./chroma_db

# ── Document Registry ────────────────────────────────────────────────────
# Path to the JSON file used as a simple document metadata store
DOC_REGISTRY_PATH=./doc_registry.json

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Add your Vercel URL after deploying the frontend
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-app.vercel.app

# ── Server ───────────────────────────────────────────────────────────────
PORT=8000
